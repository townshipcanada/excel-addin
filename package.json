{
  "name": "@townshipcanada/excel-addin",
  "version": "1.0.0",
  "private": true,
  "description": "Microsoft Excel Add-In for converting Canadian legal land descriptions to GPS coordinates",
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "validate": "npx office-addin-manifest validate manifest.xml",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "sideload": "office-addin-dev-certs install && office-addin-debugging start manifest.xml desktop"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "style-loader": "^4.0.0",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  },
  "dependencies": {
    "office-addin-manifest": "^1.13.11"
  }
}
